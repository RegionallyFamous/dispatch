# Files and directories excluded from the WordPress.org distribution zip.
# Also used by the CI plugin-check job to build a clean dist directory.

# Version control
.git/
.gitignore
.distignore

# AI / editor tooling
.cursor/
.vscode/
.idea/
.markdownlint.json

# GitHub-specific (includes screenshots, CI workflows, etc.)
.github/

# Node / npm
node_modules/
.eslintrc.js
.stylelintrc.json
.stylelintignore
package.json
package-lock.json

# Composer
# vendor/ is intentionally NOT listed — both bin/build-zip.sh and the CI
# plugin-check job run `composer install --no-dev` before rsync, so vendor/
# contains only production runtime dependencies when the dist is assembled.
# composer.json IS included so the plugin-check missing_composer_json_file
# check doesn't flag the presence of vendor/ without its manifest.
composer.lock
phpcs.xml.dist
phpunit.xml.dist
phpstan.neon
phpstan-bootstrap.php

# Build tooling
Makefile
webpack.config.js
/bin/
/src/

# Tests
tests/

# Documentation source
docs/
CODE_OF_CONDUCT.md

# Generated / local
# build/ is intentionally NOT excluded — npm run build:production compiles
# the JS bundles into build/ and they must be present in the release ZIP.
*.zip
.tmp-zip/
.phpunit.result.cache
.phpunit.cache/
coverage/
*.log

# OS
.DS_Store
Thumbs.db

# wp-env
.wp-env.json
